{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "redirects": [
    { "source": "/login", "destination": "/admin/login", "permanent": false },
    { "source": "/login/:path*", "destination": "/admin/login/:path*", "permanent": false }
  ]
}
